{
  "name": "@ansvar/sigma-rules-mcp",
  "version": "0.1.0",
  "description": "Sigma Rules MCP server with full SigmaHQ rule coverage and ATT&CK/logsource tooling",
  "mcpName": "eu.ansvar/sigma-rules",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sigma-rules-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "data/sigma_rules.db",
    "README.md",
    "LICENSE",
    "manifest.json",
    "server.json"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "build:db": "node --import tsx scripts/build-db.ts",
    "check:db-size": "node scripts/check-db-size.mjs",
    "ingest": "node --import tsx scripts/build-db.ts",
    "dev": "node --import tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:contract": "vitest run __tests__/contract/",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "ci": "npm run check:db-size && npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sigma",
    "detection-rules",
    "mitre-attack",
    "threat-detection",
    "security"
  ],
  "author": "Ansvar Systems <hello@ansvar.eu>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ansvar-Systems/sigma-rules-mcp"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ansvar/mcp-sqlite": "^1.0.3",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.29",
    "@vercel/node": "^5.6.3",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
